# HTTP server
PORT=8080

# Queue mode
USE_BULLMQ=false

# Redis connection used only when USE_BULLMQ=true
REDIS_URL=redis://127.0.0.1:6379

# Optional AI hook for chunk-level analysis
ENABLE_AI_CHUNK_ANALYSIS=false

# audio storage base url
AUDIO_BASE_URL=http://localhost:8080/audio

# storage path
AUDIO_STORAGE_PATH=./tmp/audio

